# Função que cria o tabuleiro
def criarTabuleiro():
    tabuleiro = []

    for linha in range(5):
        novaLinha = []

        for coluna in range(5):
            novaLinha.append("~")

        tabuleiro.append(novaLinha)

    return tabuleiro


# Procedimento para mostrar o tabuleiro
def mostrarTabuleiro(tabuleiro):

    print("\nTABULEIRO")

    for linha in tabuleiro:
        for coluna in linha:
            print(coluna, end=" ")
        print()


# Função que verifica se o jogador acertou
def verificarAcerto(
    linhaJogador,
    colunaJogador,
    linhaNavio,
    colunaNavio
):
    return (
        linhaJogador == linhaNavio and
        colunaJogador == colunaNavio
    )


# ==========================================
# PROGRAMA PRINCIPAL
# ==========================================

# Cria a matriz do jogo
tabuleiro = criarTabuleiro()

# Posição secreta do navio
linhaNavio = 2
colunaNavio = 3

# Quantidade de tentativas
tentativas = 5

# Variável de controle
acertou = False

print("=== BATALHA NAVAL ===")
print("Encontre o navio escondido!")
print("Linhas e colunas vão de 0 até 4.")

# Laço principal do jogo
for tentativa in range(1, tentativas + 1):

    mostrarTabuleiro(tabuleiro)

    print(f"\nTentativa {tentativa} de {tentativas}")

    linhaJogador = int(input("Digite a linha: "))
    colunaJogador = int(input("Digite a coluna: "))

    # Verifica se acertou
    if verificarAcerto(
        linhaJogador,
        colunaJogador,
        linhaNavio,
        colunaNavio
    ):

        tabuleiro[linhaJogador][colunaJogador] = "X"

        mostrarTabuleiro(tabuleiro)

        print("\nNAVIO ATINGIDO!")
        print("PARABÉNS! VOCÊ VENCEU!")

        acertou = True
        break

    else:

        tabuleiro[linhaJogador][colunaJogador] = "O"

        print("\nÁGUA!")

# Verifica se perdeu
if not acertou:

    print("\nFIM DE JOGO!")
    print("Você ficou sem tentativas.")

    # Mostra onde estava o navio
    tabuleiro[linhaNavio][colunaNavio] = "X"

    mostrarTabuleiro(tabuleiro)

    print("\nO navio estava na posição:")
    print(f"Linha {linhaNavio} - Coluna {colunaNavio}")